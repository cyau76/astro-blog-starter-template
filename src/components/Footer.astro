---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <p>© {today.getFullYear()} Jaden Au. All rights reserved.</p>

    <div class="links">
      <a href="mailto:cyau@cyau76.com">Email</a>
      <a href="https://www.linkedin.com/in/cyau76" target="_blank">LinkedIn</a>
      <a href="https://github.com/cyau76" target="_blank">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 2.5em 1em;
    background: #111;
    color: #aaa;
    text-align: center;
    margin-top: 4em;
  }

  .footer-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .links {
    display: flex;
    justify-content: center;
    gap: 1.5em;
    margin-top: 1em;
    flex-wrap: wrap;
  }

  .links a {
    color: #aaa;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .links a:hover {
    color: white;
  }
</style>
